DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
REDIS_URL=redis://redis:6379/0
JOB_QUEUE_KEY=openclaw:jobs
JOB_STATUS_PREFIX=openclaw:job:

# Discord から扱ってよいリポジトリをカンマ区切りで指定
ALLOWED_REPOS=https://github.com/your-org/your-repo.git

# clone や push に使う GitHub token
GITHUB_TOKEN=

# /create-project でリポジトリ作成先の GitHub org またはユーザー名
GITHUB_DEFAULT_ORG=

# host 側の Codex 設定ディレクトリ
CODEX_HOST_CONFIG_DIR=/root/.codex

# worker が使う作業ディレクトリ
WORKSPACE_ROOT=/workspace/jobs

# OpenClaw 実行ラッパ
OPENCLAW_RUNNER=/app/run_openclaw.sh

# Codex 実行設定
CODEX_MODEL=
CODEX_PROFILE=
CODEX_SANDBOX=workspace-write

# GitHub Webhook (PR コメント自動修正用)
GITHUB_WEBHOOK_SECRET=
OPENCLAW_TRIGGER=@openclaw

# Chat mode: チャンネルIDをカンマ区切りで指定すると、そのチャンネルのメッセージを自動処理
CHAT_CHANNEL_IDS=
CHAT_DEFAULT_REPO=
CHAT_POLL_INTERVAL=3

# Discord bot 側のデフォルト
DEFAULT_BRANCH=main

# Slash Command を同期するかどうか
SYNC_COMMANDS=true
